						{"qi_f":"query.get_equipped_item_name=='qi' && query.scoreboard('qi') >= 15 && query.scoreboard('qi') < 18 && query.is_using_item && query.player_level >= 25"},
						{"qi_g":"query.get_equipped_item_name=='qi' && query.scoreboard('qi') >= 18"}
