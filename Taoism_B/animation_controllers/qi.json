{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.qi":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"qi_a":"query.get_equipped_item_name=='qi' && query.scoreboard('qi') < 3 && query.is_using_item && query.player_level >= 25"},
						{"qi_b":"query.get_equipped_item_name=='qi' && query.scoreboard('qi') >= 3 && query.scoreboard('qi') < 6 && query.is_using_item && query.player_level >= 25"},
