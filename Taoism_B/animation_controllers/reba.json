						"/say §c精滋养身心，气推动运化，神统摄精气，三者缺一不可。"
					]
				},
				"reba_g": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §c所谓修炼，便是性命双修：修命则炼精炼气，脱胎换骨；修性则炼神合道，明心见性。"
					]
				},
				"reba_h": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
