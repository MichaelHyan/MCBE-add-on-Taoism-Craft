{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.flo":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"floa":"query.life_time <= 15"},
						{"flob":"query.life_time > 15"}
					]
				},
				"floa": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/damage @e[type=!arrow,type=!player,type=!item,type=!villager,type=!armor_stand,family=!taoism,r=2] 1",
						"/effect @e[type=player,r=2] regeneration 1 1 true",
						"/particle minecraft:blue_flame_particle ~ ~1 ~"
					]
				},
				"flob": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/kill @s"
					]
				}
			}
		}
 	}
 }