					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 这个实体的代码和盟友系统其实是一模一样的。。。除了没有对法器的免疫处理。"
					]
				},
				"h_chat_f": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 盟友系统最开始是个目的于陪伴玩家的设计，后来才拥有了对话和交互。"
					]
				},
				"h_chat_g": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 你敢信这些剑在3.0版本前是无限耐久也没有等级限制的？"
					]
				},
				"h_chat_h": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 使用符箓的时候消耗逻辑其实是把他吃下去。。。之前甚至能回饱食度（张角：这我熟啊）"
					]
				},
				"h_chat_i": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 人有没有来世呢？不管有没有，只有这一世的你是现在的你，去做现在的你应当去做的吧。"
					]
				},
				"h_chat_j": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 这个世界的主线任务就是打那个黑黑的龙吗？"
					]
				},
				"h_chat_k": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 有时候我想设计一个很帅的武器，有三种颜色状态，大招是飞起来然后从空中劈下去。。。"
					]
				},
				"h_chat_l": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
