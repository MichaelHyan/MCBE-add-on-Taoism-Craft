					"on_entry": [
						"/say 谢谢，不过剧透嘛。。。我也不知道，可以去我的GitHub仓库看看，有点子的时候会更新的 https://github.com/MichaelHyan/MCBE-add-on-Taoism-Craft",
						"/replaceitem entity @s slot.weapon.mainhand 0 air"
					]
				},
				"h_chat_se": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say 其实我们原本是想做朱砂矿的，但是当时没学会自定义方块。。。然后一年后麻将给辰砂块加进来了（还有这种好事？）",
						"/replaceitem entity @s slot.weapon.mainhand 0 air",
						"/give @p items:cinnabar_crystal"
					]
				}
			}
		}
 	}
 }