{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.bss":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"bss_a":"query.life_time < 1"},
						{"bss_b":"query.life_time >= 1"}
					]
				},
				"bss_a": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/particle minecraft:balloon_gas_particle ~ ~0.2 ~",
						"/effect @s resistance 1 255 true"
					]
				},
				"bss_b": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/kill @s"
					]
				}
			}
		}
 	}
 }