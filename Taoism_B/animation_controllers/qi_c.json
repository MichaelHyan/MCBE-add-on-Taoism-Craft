{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.qi_c":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"qi_c_a":"query.get_equipped_item_name=='qi_c' && !query.is_using_item && query.scoreboard('qic') < 70 && query.scoreboard('qic') >= 0"},
						{"qi_c_b":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 60"},
						{"qi_c_c":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 50 && query.scoreboard('qic') <= 60"},
						{"qi_c_d":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 40 && query.scoreboard('qic') <= 50"},
						{"qi_c_e":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 30 && query.scoreboard('qic') <= 40"},
						{"qi_c_f":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 20 && query.scoreboard('qic') <= 30"},
						{"qi_c_g":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') > 10 && query.scoreboard('qic') <= 20"},
						{"qi_c_h":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') >= 0 && query.scoreboard('qic') <= 10"},
						{"qi_c_i":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') == -1"},
						{"qi_c_j":"query.get_equipped_item_name=='qi_c' && query.is_using_item && query.scoreboard('qic') == -2"},
						{"qi_c_k":"query.get_equipped_item_name=='qi_c' && !query.is_using_item && query.scoreboard('qic') <= -1"}
					]
				},
				"qi_c_a": {
