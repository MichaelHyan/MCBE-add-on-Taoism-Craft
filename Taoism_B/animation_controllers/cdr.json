{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.cdr":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"cdr_a":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 0"},
						{"cdr_b":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 1"},
						{"cdr_c":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 2"},
						{"cdr_d":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 3"},
						{"cdr_e":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 4"},
						{"cdr_f":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 5"},
						{"cdr_g":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 6"},
						{"cdr_h":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 7"},
						{"cdr_i":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') == 8"},
						{"cdr_j":"query.get_equipped_item_name=='spe' && query.is_using_item && query.scoreboard('cdr') >= 9"},
						{"cdr_k":"query.scoreboard('cdr') >= 3 && query.scoreboard('charge') < -5 || query.scoreboard('bell') < -5"}
					]
				},
				"cdr_a": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
