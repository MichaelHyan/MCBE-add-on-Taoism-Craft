{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.ring":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"ring_ea":"query.life_time < 3"},
						{"ring_eb":"query.life_time >= 3"}
					]
				},
				"ring_ea": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/particle minecraft:balloon_gas_particle ~ ~1 ~",
						"/tp ^ ^ ^1 facing @n[tag=qlock]",
						"/damage @e[tag=qlock,r=3] 8",
						"/effect @e[tag=qlock,r=3] weakness 10 255 true",
						"/tag @e[r=3] remove qlock"
					]
				},
				"ring_eb": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/effect @s invisibility 1 1 true",
						"/kill @s"
					]
				}
			}
		}
 	}
 }