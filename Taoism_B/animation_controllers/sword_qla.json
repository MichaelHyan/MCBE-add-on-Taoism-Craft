{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.sword_qla":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"sword_qla_a":"query.get_equipped_item_name=='sword_ql' && !query.is_sneaking && query.scoreboard('charge') < 10"},
						{"sword_qla_b":"query.get_equipped_item_name=='sword_ql' && !query.is_sneaking && query.scoreboard('charge') >= 10"},
						{"sword_qla_c":"query.get_equipped_item_name=='sword_ql' && query.is_sneaking && query.scoreboard('charge') >= 10"}
					]
				},
				"sword_qla_a": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/effect @s strength 1 3 true",
						"/scoreboard players add @s charge 1"
					]
				},
				"sword_qla_b": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/effect @s strength 1 3 true"
					]
				},
				"sword_qla_c": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/give @s items:talisman_ql 7",
						"/kill @e[type=entity:talisman_ql]",
						"/scoreboard players set @s charge 0"
					]
				}
			}
		}
 	}
 }