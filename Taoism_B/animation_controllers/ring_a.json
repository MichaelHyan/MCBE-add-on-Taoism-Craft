                        {"ring_cl":"query.player_level > 24 && query.get_equipped_item_name=='ring' && query.is_using_item && query.scoreboard('chargea') == 11"},
                        {"ring_cm":"query.player_level > 24 && query.get_equipped_item_name=='ring' && query.is_using_item && query.scoreboard('chargea') == 12"}
