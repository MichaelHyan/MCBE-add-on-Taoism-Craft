					"on_entry": [
						"/say §c如果你想要的答案是修炼成仙，那我确实不知道怎么去帮你。但如果你想问的是长生的事，我认为你自己能找到这个答案。"
					]
				},
				"rebb_n": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §7。。。"
					]
				},
				"rebb_o": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
