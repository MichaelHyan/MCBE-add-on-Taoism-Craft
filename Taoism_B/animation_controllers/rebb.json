					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §c急功近利毕竟是人的天性……人最恐惧的，莫过于死亡。而世人眼中的修仙，恰好被当成了规避死亡的捷径。"
					]
				},
				"rebb_h": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §c却不知，真正的修仙，是修一颗与道相合的心，长生不过是水到渠成的结果。若只执着于肉体永存，终究是本末倒置。"
					]
				},
				"rebb_i": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §9那我们对此能选择的，只剩下修炼这条路吗？"
					]
				},
				"rebb_j": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §c你绕了这么多弯，想问的从来都不是“众生该如何”，而是“你该如何”。"
					]
				},
				"rebb_k": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/say §c你先天不足，无法炼精化炁，连最基础的桃木剑都驱动不了，对吗？"
					]
				},
				"rebb_l": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
