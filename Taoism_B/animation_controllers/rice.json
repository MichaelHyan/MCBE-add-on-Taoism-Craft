						"/effect @e[r=3,family=undead] wither 1 1",
						"/damage @e[tag=???,r=3] 20",
						"/particle minecraft:cauldron_explosion_emitter ~ ~ ~"
					]
				},
				"rice_b": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/kill @s"
					]
				}
			}
		}
 	}
 }