{
	"format_version": "1.8.0",
	"animation_controllers": {
		"controller.animation.banner":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"soul_banner_a":"query.get_equipped_item_name=='soul_banner' && !variable.attack_time && query.player_level > 24 && query.scoreboard('spirit') >= 4"},
						{"soul_banner_e":"query.get_equipped_item_name=='soul_banner' && !variable.attack_time && query.player_level > 24 && query.scoreboard('spirit') < 4"},
						{"soul_banner_b":"query.get_equipped_item_name=='soul_banner' && variable.attack_time && query.is_sneaking && query.player_level > 24 && query.scoreboard('spirit') >= 4"},
						{"soul_banner_c":"query.get_equipped_item_name=='soul_banner' && variable.attack_time && query.is_sneaking && query.player_level > 24 && query.scoreboard('spirit') < 4"},
						{"soul_banner_d":"query.get_equipped_item_name=='soul_banner' && variable.attack_time && !query.is_sneaking && query.player_level > 24"},
						{"hy_banner_a":"query.get_equipped_item_name=='hy_banner' && !variable.attack_time && query.player_level > 24"},
						{"hy_banner_b":"query.get_equipped_item_name=='hy_banner' && variable.attack_time && query.is_sneaking && query.player_level > 24 && query.scoreboard('charge') >= 0"},
						{"hy_banner_c":"query.get_equipped_item_name=='hy_banner' && variable.attack_time && !query.is_sneaking && query.player_level > 24"}
					]
				},
				"soul_banner_a": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/effect @s resistance 1 3 true",
						"/effect @s hunger 1 5 true",
						"/effect @s speed 1 1 true",
						"/particle minecraft:wither_boss_invulnerable ^ ^ ^",
						"/scoreboard objectives add spirit dummy"
					]
				},
				"soul_banner_e": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/title @s actionbar 魂魄不足",
						"/effect @s resistance 1 3 true",
						"/effect @s speed 1 1 true",
						"/scoreboard objectives add spirit dummy"
					]
				},
				"soul_banner_b": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/effect @e[r=15,type=!player] slowness 10 255 true",
						"/summon entity:zombie_friendly",
						"/summon entity:zombie_friendly",
						"/summon entity:zombie_friendly",
						"/particle minecraft:totem_particle ~ ~1 ~",
						"/scoreboard players add @s spirit -4"
					]
				},
				"soul_banner_c": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/summon entity:zombie_friendly",
						"/damage @s 2",
						"/particle minecraft:totem_particle ~ ~1 ~"
					]
				},
				"soul_banner_d": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/particle minecraft:critical_hit_emitter ^ ^2.8 ^2.5",
						"/enchant @s mending"
					]
				},
				"hy_banner_a": {
					"transitions": [
							{
								"base_jeta": "(1.0)"
							}
					],
					"on_entry": [
						"/effect @s resistance 1 3 true",
						"/effect @s hunger 1 5 true",
						"/effect @s speed 1 1 true",
						"/effect @e[tag=ig,r=3] instant_health 1 1 true",
						"/scoreboard objectives add charge dummy"
					]
				},
				"hy_banner_b": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/effect @e[r=15,type=!player] slowness 10 255 true",
						"/summon iron_golem ~1 ~ ~",
						"/summon iron_golem ~-1 ~ ~",
						"/summon iron_golem ~ ~ ~1",
						"/summon iron_golem ~ ~ ~-1",
						"/tag @e[type=iron_golem,r=5] add ig",
						"/effect @e[tag=ig] strength infinite 10 true",
						"/effect @e[tag=ig] speed infinite 10 true",
						"/effect @e[tag=ig] wither infinite 255 true",
						"/particle minecraft:totem_particle ~ ~1 ~",
						"/scoreboard players set @s charge -150"
					]
				},
				"hy_banner_c": {
					"transitions": [
						{
							"base_jeta": "(1.0)"
						}
					],
					"on_entry": [
						"/particle minecraft:critical_hit_emitter ^ ^2.8 ^2.5",
						"/enchant @s smite 3",
						"/enchant @s mending"
					]
				}
			}
		}
 	}
 }