		"controller.animation.acbook":{
			"states":{
				"base_jeta":{
					"transitions":[
						{"acbook_turn_a":"query.get_equipped_item_name=='acbook' && query.is_using_item && query.scoreboard('charge') >= 0 && query.scoreboard('chapter') <= 8 && query.scoreboard('maxchapter') <= 8"},
						{"acbook_turn_b":"query.get_equipped_item_name=='acbook' && query.scoreboard('chapter') > 8 && query.scoreboard('maxchapter') <= 8"},
						{"acbook_turn_c":"query.get_equipped_item_name=='acbook' && query.is_using_item && query.scoreboard('charge') >= 0 && query.scoreboard('chapter') <= 9 && query.scoreboard('maxchapter') == 9"},
						{"acbook_turn_b":"query.get_equipped_item_name=='acbook' && query.scoreboard('chapter') > 9 && query.scoreboard('maxchapter') == 9"},
						{"acbook_unread":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') > query.scoreboard('maxchapter') && query.scoreboard('charge') >= 0"},
						{"acbook_read_a":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 1"},
						{"acbook_read_b":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 2"},
						{"acbook_read_c":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 3"},
						{"acbook_read_d":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 4"},
						{"acbook_read_e":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 5"},
						{"acbook_read_f":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 6"},
						{"acbook_read_g":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 7"},
						{"acbook_read_h":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 8"},
						{"acbook_read_i":"query.get_equipped_item_name=='acbook' && variable.attack_time && query.scoreboard('chapter') <= query.scoreboard('maxchapter') && query.scoreboard('chapter') == 9"},
						{"acbook_unlock_a":"query.get_equipped_item_name=='crafting_table' && query.scoreboard('maxchapter') == 0 && query.scoreboard('chapter') != 0"},
						{"acbook_unlock_b":"query.get_equipped_item_name=='cinnabar_powder' && query.scoreboard('maxchapter') == 1"},
						{"acbook_unlock_c":"query.get_equipped_item_name=='talisman' && query.scoreboard('maxchapter') == 2"},
						{"acbook_unlock_d":"query.get_equipped_item_name=='qi' && query.scoreboard('maxchapter') == 3"},
						{"acbook_unlock_e":"query.get_equipped_item_name=='totem_of_undying' && query.scoreboard('maxchapter') == 4"},
						{"acbook_unlock_f":"query.get_equipped_item_name=='nether_star' && query.scoreboard('maxchapter') == 5"},
						{"acbook_unlock_g":"query.get_equipped_item_name=='ender_eye' && query.scoreboard('maxchapter') == 6"},
						{"acbook_unlock_h":"query.get_equipped_item_name=='partner' && query.scoreboard('maxchapter') == 7"}
					]
